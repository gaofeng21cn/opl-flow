{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gaofeng21cn/opl-flow/contracts/workflow-policy.schema.json",
  "title": "OPL Flow workflow policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "package",
    "workflow_generation",
    "provides",
    "requires",
    "recommends",
    "compatible_optional",
    "installation_convergence",
    "conflicts",
    "retires",
    "codex_model_policy",
    "migration_policy",
    "historical_fingerprints"
  ],
  "properties": {
    "$schema": { "const": "./workflow-policy.schema.json" },
    "schema": { "const": "opl_flow_workflow_policy.v2" },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "owner", "kind"],
      "properties": {
        "id": { "const": "opl-flow" },
        "version": { "type": "string", "minLength": 1 },
        "owner": { "const": "opl-flow" },
        "kind": { "const": "workflow_profile" }
      }
    },
    "workflow_generation": { "type": "string", "minLength": 1 },
    "provides": { "$ref": "#/$defs/providedCapabilities" },
    "requires": { "$ref": "#/$defs/dependencies" },
    "recommends": { "$ref": "#/$defs/dependencies" },
    "compatible_optional": { "$ref": "#/$defs/dependencies" },
    "installation_convergence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standard_target_closure",
        "full_target_closure",
        "standard_source",
        "full_source",
        "final_projection_equivalence_required",
        "default_dependencies_require_full_bundle",
        "secrets_bundled",
        "user_third_party_surfaces_policy"
      ],
      "properties": {
        "standard_target_closure": { "const": "workflow_policy_release_lock" },
        "full_target_closure": { "const": "workflow_policy_release_lock" },
        "standard_source": { "const": "online_exact_release_lock" },
        "full_source": { "const": "embedded_exact_release_lock" },
        "final_projection_equivalence_required": { "const": true },
        "default_dependencies_require_full_bundle": { "const": true },
        "secrets_bundled": { "const": false },
        "user_third_party_surfaces_policy": { "const": "preserve" }
      }
    },
    "conflicts": { "$ref": "#/$defs/migrations" },
    "retires": { "$ref": "#/$defs/migrations" },
    "codex_model_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "mode_default", "configured_default", "override_precedence", "catalog_policy"],
      "properties": {
        "authority": { "const": "opl-flow" },
        "mode_default": { "const": "auto" },
        "configured_default": {
          "type": "object",
          "additionalProperties": false,
          "required": ["model", "reasoning_effort"],
          "properties": {
            "model": { "type": "string", "minLength": 1 },
            "reasoning_effort": { "type": "string", "minLength": 1 }
          }
        },
        "override_precedence": {
          "type": "array",
          "minItems": 3,
          "items": { "type": "string", "minLength": 1 }
        },
        "catalog_policy": { "type": "object" }
      }
    },
    "migration_policy": { "type": "object" },
    "historical_fingerprints": { "type": "object" }
  },
  "$defs": {
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "owner",
        "version_requirement",
        "source",
        "install_source",
        "lifecycle_owner",
        "online_install_default",
        "offline_bundle",
        "activation",
        "conflict_policy",
        "credential_policy"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["base", "codex_skill", "codex_plugin", "mcp_server", "cli", "runtime_capability"] },
        "owner": { "type": "string", "minLength": 1 },
        "version_requirement": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "install_source": { "enum": ["package_payload", "framework_managed_release_lock", "codex_builtin", "user_managed"] },
        "lifecycle_owner": { "type": "string", "minLength": 1 },
        "online_install_default": { "type": "boolean" },
        "offline_bundle": { "enum": ["none", "full"] },
        "activation": { "enum": ["always", "task_routed", "explicit"] },
        "conflict_policy": { "enum": ["managed_reconcile", "preserve_user_surface", "fail_closed_on_collision"] },
        "credential_policy": { "enum": ["none", "user_or_provider_owned_not_bundled"] }
      }
    },
    "providedCapabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "allOf": [
          { "$ref": "#/$defs/capability" },
          {
            "properties": {
              "kind": { "enum": ["codex_skill", "codex_plugin"] },
              "install_source": { "const": "package_payload" },
              "lifecycle_owner": { "const": "opl-framework" },
              "online_install_default": { "const": true },
              "offline_bundle": { "const": "full" },
              "credential_policy": { "const": "none" }
            }
          }
        ]
      }
    },
    "dependencies": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/capability" }
    },
    "migrations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "discovery_ids", "config_markers", "service_ids", "auto_retire_on_optimize", "reason"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "discovery_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "config_markers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "service_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "auto_retire_on_optimize": { "type": "boolean" },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
